# Backend runtime
APP_ENV=development
LOG_LEVEL=info
PORT=8000
RUN_DB_INIT=true

# Database and cache
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cd_se_accelerators
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_GRPC=false
QDRANT_COLLECTION_NAME=brd_chunks
QDRANT_VECTOR_SIZE=768
QDRANT_TIMEOUT=30.0

# Model provider
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT=60.0
MODEL_TOP_P=1.0
MODEL_MAX_RETRIES=3

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Embeddings and retrieval
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY=1.0
EMBEDDING_CACHE_ENABLED=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_CANDIDATE_COUNT=20
RERANKER_FINAL_COUNT=5
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_RRF_K=60

# Chunking and labeling
CHUNK_MAX_TOKENS=300
CHUNK_MIN_TOKENS=90
SEMANTIC_CHUNKING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_CHUNKING_SIMILARITY_THRESHOLD=0.65
CONTEXT_LABELING_BATCH_SIZE=20
CONTEXT_LABELING_MAX_TOKENS=1000
