# MCP Server — Required credentials
# These are already in backend/.env — no separate file needed.
# This file documents which keys the MCP server reads.

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# ── Google Drive ──────────────────────────────────────────────────────────────
# No env vars needed. Google Drive uses OAuth2 via:
#   mcp_server/credentials/client_secret.json   ← downloaded from GCP Console
#   mcp_server/credentials/token.json           ← auto-generated on first run
