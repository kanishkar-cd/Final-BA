# ─────────────────────────────────────────────────────────────────────────────
# BA Accelerator – Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# LLM Providers (Leave these blank in this example file!)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
CEREBRAS_FALLBACK_MODEL=gpt-oss-120b
ENABLE_NLP_RAG=false

# ─────────────────────────────────────────────────────────────────────────────
# Semantic Chunking
# ─────────────────────────────────────────────────────────────────────────────

CHUNK_MAX_TOKENS=300
FAST_DOCUMENT_CHUNKING=true
CHUNK_MIN_TOKENS=90
REQUIREMENT_ANALYSIS_MAX_INPUT_CHARS=18000
SEMANTIC_CHUNKING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_CHUNKING_SIMILARITY_THRESHOLD=0.65


# ─────────────────────────────────────────────────────────────────────────────
# Context Labeling
# ─────────────────────────────────────────────────────────────────────────────

CONTEXT_LABELING_BATCH_SIZE=8
CONTEXT_LABELING_MAX_TOKENS=2000
CONTEXT_LABELING_FALLBACK_MODEL=llama3.1-8b
CEREBRAS_FALLBACK_MODEL=llama3.1-8b


# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL  (used by BM25 search and the indexing service)
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require


# ─────────────────────────────────────────────────────────────────────────────
# Redis  (session, workflow, and RAG query result caching)
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=rediss://default:gQAAAAAAAa8gAAIgcDJhZDlkNWUxMTQyZTM0NWM1Yjg0ODdiOTFiNTU3NDgzNg@moral-deer-110368.upstash.io:6379
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_CONNECT_TIMEOUT_SECONDS=5


# ─────────────────────────────────────────────────────────────────────────────
# Qdrant Vector Database
#
# QDRANT_COLLECTION_NAME   – collection that holds chunk embeddings
#                            default: brd_chunks
# QDRANT_VECTOR_SIZE       – must match the embedding model output dimension
#                            BAAI/bge-base-en-v1.5 → 768
# QDRANT_API_KEY           – leave blank for local / unsecured instances
# QDRANT_USE_GRPC          – set to "true" to use gRPC transport (faster for
#                            high-throughput batch indexing)
# ─────────────────────────────────────────────────────────────────────────────

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_GRPC=false
QDRANT_COLLECTION_NAME=brd_chunks
QDRANT_VECTOR_SIZE=768
QDRANT_TIMEOUT=30.0


# ─────────────────────────────────────────────────────────────────────────────
# Embedding Generation  (BAAI/bge-base-en-v1.5)
#
# EMBEDDING_MODEL_NAME     – HuggingFace model ID; change only if you switch
#                            models (remember to update QDRANT_VECTOR_SIZE too)
# EMBEDDING_BATCH_SIZE     – texts encoded per model.encode() call; tune for
#                            available VRAM / RAM
# EMBEDDING_MAX_RETRIES    – transient failure retries with exponential backoff
# EMBEDDING_RETRY_DELAY    – initial backoff delay in seconds (doubles each retry)
# EMBEDDING_CACHE_ENABLED  – set to "false" to skip Redis embedding cache
# ─────────────────────────────────────────────────────────────────────────────

EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY=1.0
EMBEDDING_CACHE_ENABLED=true


# ─────────────────────────────────────────────────────────────────────────────
# Cross-Encoder Reranker  (BAAI/bge-reranker-base)
#
# RERANKER_CANDIDATE_COUNT – top-N chunks from RRF fed to the cross-encoder
# RERANKER_FINAL_COUNT     – top-M chunks returned after reranking
# ─────────────────────────────────────────────────────────────────────────────

RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_CANDIDATE_COUNT=20
RERANKER_FINAL_COUNT=5


# ─────────────────────────────────────────────────────────────────────────────
# Hybrid Retrieval Pipeline
#
# RETRIEVAL_DENSE_TOP_K    – Qdrant results per query before RRF
# RETRIEVAL_BM25_TOP_K     – PostgreSQL FTS results per query before RRF
# RETRIEVAL_RRF_K          – RRF smoothing constant (Cormack et al. 2009)
#                            higher value = less rank compression
#                            default 60 matches the original paper
# ─────────────────────────────────────────────────────────────────────────────

RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_RRF_K=60

